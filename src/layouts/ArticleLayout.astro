---
import BaseLayout from "./BaseLayout.astro";
import HeroPortraitFigure from "../components/HeroPortraitFigure.astro";
import KeyStats from "../components/KeyStats.astro";
import SidebarToc from "../components/SidebarToc.astro";
import Pagination from "../components/Pagination.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import RelatedArticles from "../components/RelatedArticles.astro";
import ReturnToOverview from "../components/ReturnToOverview.astro";

interface Props {
  num: string;
  title: string;
  subtitle: string;
  badge: string;
  description: string;
  readTime: string;
  stats: Array<{ num: string; label: string }>;
  headings: Array<{ depth: number; slug: string; text: string }>;
}
const { num, title, subtitle, badge, description, readTime, stats, headings } = Astro.props;
---
<BaseLayout title={title} description={description} articleNum={num}>
  <ReadingProgress />

  <header class="article-hero relative overflow-hidden border-b border-[var(--color-rule-hair)]">
    <div class="container-wide py-12 md:py-20 lg:py-24">
      <div class="grid items-end gap-12 lg:gap-16 lg:grid-cols-[1fr_420px]">

        <div class="hero-text min-w-0 max-w-[42rem] order-2 lg:order-1">

          <div class="flex items-baseline gap-3 mb-8">
            <span class="eyebrow eyebrow-primary">系列文章</span>
            <span class="tabular-display text-sm tracking-[0.2em] text-[var(--color-ink-faint)]">
              No. {num} / 12
            </span>
            <hr class="rule-hairline flex-1 ml-2" />
          </div>

          <span class="inline-block px-3 py-1
                       border border-[var(--color-rule-bold)]
                       text-[11px] tracking-[0.2em] uppercase font-semibold
                       text-[var(--color-primary)]
                       rounded-full mb-6">
            {badge}
          </span>

          <h1 class="editorial-h1 text-[var(--color-ink)] mb-6 md:mb-8">
            {title}
          </h1>

          <p class="body-lg text-[var(--color-ink-muted)] max-w-[40rem] font-light">
            {subtitle}
          </p>

          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-8
                      text-[11px] tracking-[0.15em] uppercase
                      text-[var(--color-ink-faint)]">
            <span>第 {num} 篇 / 共 12 篇</span>
            <span class="text-[var(--color-rule-bold)]" aria-hidden="true">·</span>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
                <circle cx="6" cy="6" r="5"/><path d="M6 3v3l2 1.5"/>
              </svg>
              閱讀 {readTime}
            </span>
          </div>

          <KeyStats stats={stats} />
        </div>

        <div class="order-1 lg:order-2 flex justify-center lg:block">
          <HeroPortraitFigure variant="article" />
        </div>
      </div>
    </div>
  </header>

  <div class="container-wide grid gap-12 md:gap-16 lg:gap-20 lg:grid-cols-[minmax(0,1fr)_280px]
              pt-10 pb-12 md:py-24">

    <article
      id="article-top"
      class="article-body min-w-0 max-w-none lg:max-w-[42rem]"
    >
      <slot />
    </article>

    <SidebarToc headings={headings} currentNum={num} />
  </div>

  <div class="container-wide">
    <Pagination currentNum={num} />
    <ReturnToOverview />
    <RelatedArticles currentNum={num} />
  </div>

  <ScrollReveal />
</BaseLayout>

<style>
  /* === Article body editorial styling === */
  .article-body :global(h2) {
    font-family: var(--font-display-cjk);
    color: var(--color-ink);
    font-weight: 700;
    font-size: clamp(1.5rem, 1.5vw + 1rem, 2.25rem);
    line-height: 1.25;
    letter-spacing: -0.015em;
    text-wrap: balance;
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-rule-hair);
  }
  .article-body :global(h2)::before {
    content: "§";
    display: inline-block;
    margin-right: 0.5em;
    color: var(--color-primary);
    font-family: var(--font-display-latin);
    font-style: italic;
    font-weight: 400;
    opacity: 0.7;
  }

  .article-body :global(h3) {
    font-family: var(--font-display-cjk);
    color: var(--color-ink);
    font-weight: 700;
    font-size: 1.25rem;
    margin-top: 3rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
    position: relative;
    padding-left: 1rem;
  }
  .article-body :global(h3)::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45em;
    bottom: 0.45em;
    width: 3px;
    background: var(--color-primary);
    border-radius: 2px;
  }

  .article-body :global(p) {
    font-family: var(--font-body-cjk);
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--color-ink);
    margin: 1.25rem 0;
  }

  .article-body :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  .article-body :global(a) {
    color: var(--color-primary);
    font-weight: 500;
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.3s ease;
  }
  .article-body :global(a:hover) {
    background-size: 100% 2px;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }
  .article-body :global(li) {
    margin: 0.5rem 0;
    color: var(--color-ink);
    line-height: 1.85;
  }
  .article-body :global(li)::marker {
    color: var(--color-primary);
  }

  /* 第一段 drop cap — 不限制 direct child（Astro Content 可能包 wrapper）*/
  .article-body :global(p:first-of-type::first-letter) {
    font-family: var(--font-display-cjk);
    font-weight: 900;
    font-size: 4.2em;
    line-height: 0.9;
    float: left;
    margin: 0.05em 0.12em -0.05em 0;
    color: var(--color-primary);
  }

  /* Blockquote — pull quote */
  .article-body :global(blockquote) {
    margin: 2.5rem 0;
    padding: 0.5rem 1.5rem 0.5rem 2.5rem;
    position: relative;
    font-family: var(--font-display-cjk);
    font-size: 1.25rem;
    line-height: 1.55;
    font-weight: 500;
    color: var(--color-ink);
    border: 0;
    font-style: normal;
  }
  .article-body :global(blockquote)::before {
    content: "\201C";
    position: absolute;
    left: 0.3rem;
    top: -0.4em;
    z-index: 1;
    font-family: var(--font-display-latin);
    font-size: 4rem;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.35;
    font-style: italic;
    pointer-events: none;
  }
  .article-body :global(blockquote)::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0.5rem;
    bottom: 0.5rem;
    z-index: 0;
    width: 2px;
    background: var(--color-primary);
  }

  .article-body :global(table) {
    width: 100%;
    margin: 2rem 0;
    border-collapse: collapse;
    font-size: 14px;
  }
  .article-body :global(th) {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid var(--color-rule-bold);
    color: var(--color-ink);
  }
  .article-body :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-rule-hair);
    color: var(--color-ink-muted);
  }

  .article-body :global(hr) {
    margin: 3rem 0;
    border: 0;
    height: 1px;
    background: var(--color-rule-hair);
  }

  .article-body :global(code) {
    background: var(--color-paper-warm);
    border: 1px solid var(--color-rule-hair);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--color-primary-deep);
  }

  /* Hero text fade-in */
  .hero-text {
    opacity: 1;
    transform: none;
    animation: hero-fade-in 1.1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes hero-fade-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-text { animation: none; }
    :global(.reveal),
    :global(.revealed) { opacity: 1; transform: none; transition: none; }
  }

  @media (max-width: 640px) {
    .article-body :global(table) {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      font-size: 13px;
    }
    .article-body :global(th),
    .article-body :global(td) {
      min-width: 5rem;
      white-space: nowrap;
    }
  }
</style>
