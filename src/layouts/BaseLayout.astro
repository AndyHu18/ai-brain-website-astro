---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../consts";

interface Props {
  title: string;
  description?: string;
  articleNum?: string;
  /** 若 true，title 不附加「| 網站經營 12 篇系列」後綴（避免重複）*/
  exactTitle?: boolean;
}
const { title, description = SITE.tagline, articleNum, exactTitle = false } = Astro.props;
const fullTitle = exactTitle ? title : `${title} | ${SITE.seriesName}`;
---
<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#1a0f0a" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta name="generator" content={Astro.generator} />

    {/* Noto fonts — Fraunces & Inter 已在 global.css 透過 @import 載入 */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700;900&family=Noto+Serif+TC:wght@500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen body-with-fixed-nav">
    <Navbar articleNum={articleNum} />
    <slot />
    <Footer />
  </body>
</html>
