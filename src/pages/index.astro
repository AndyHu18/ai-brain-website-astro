---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SERIES_ARTICLES } from "../consts";
---
<BaseLayout title="開發中" description="ai-brain 12 篇文章 Astro 重構版">
  <main class="container-narrow py-16">
    <h1 class="fluid-h1 font-serif">12 篇文章 Astro 重構（dev）</h1>
    <p class="mt-4 text-[var(--color-text-muted)]">這是 dev 預覽頁。實際線上首頁仍是舊版 ai-brain-website。</p>
    <ol class="mt-8 space-y-2">
      {SERIES_ARTICLES.map(a => (
        <li>
          <a href={`/articles/${a.slug}/`} class="block p-4 border border-[var(--color-border-subtle)] rounded-lg
                                                  hover:border-[var(--color-primary)] transition-colors">
            <span class="font-bold text-[var(--color-primary)]">第 {a.num} 篇</span>
            <span class="ml-3 text-[var(--color-text-primary)]">{a.shortTitle}</span>
          </a>
        </li>
      ))}
    </ol>
  </main>
</BaseLayout>
