---
// 漸進增強 scroll reveal
// 預設 .reveal 內容可見（無 JS / JS 失敗時不會空白）；
// 此元件先 mark <html class="js">（CSS 看到才隱藏 + 等 observer 觸發）
---
{/* inline blocking script: 讓 CSS 在第一次 paint 前就知道 JS 可用 */}
<script is:inline>
  document.documentElement.classList.add("js");
</script>

<script>
  // IntersectionObserver 觸發 .revealed — 含 fallback timeout 保證內容絕對可見
  const reveals = document.querySelectorAll(".reveal");
  if ("IntersectionObserver" in window && reveals.length > 0) {
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("revealed");
            obs.unobserve(e.target);
          }
        });
      },
      { rootMargin: "100px 0px 100px 0px", threshold: 0 } // 寬鬆觸發，buffer 100px
    );
    reveals.forEach((el) => obs.observe(el));

    // 防呆：滾動超過 1 秒後若仍有未 reveal 的元素，全部強制顯示
    // 避免 fast scroll 漏掉元素導致空白
    let lastScrollTime = Date.now();
    const onScroll = () => { lastScrollTime = Date.now(); };
    window.addEventListener("scroll", onScroll, { passive: true });

    setInterval(() => {
      if (Date.now() - lastScrollTime > 1000) {
        document.querySelectorAll(".reveal:not(.revealed)").forEach((el) => {
          const r = el.getBoundingClientRect();
          // 已滾過視窗（在視窗上方）→ 強制顯示
          if (r.bottom < 0) {
            el.classList.add("revealed");
            obs.unobserve(el);
          }
        });
      }
    }, 1500);
  } else {
    // 不支援 observer → 全部直接顯示
    reveals.forEach((el) => el.classList.add("revealed"));
  }
</script>
