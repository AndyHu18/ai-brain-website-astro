---
interface Props {
  src: string;
  title: string;
  episode?: string;
}
const { src, title, episode = "" } = Astro.props;
const playerId = `podcast-${src.replace(/[^a-zA-Z0-9]/g, "-")}`;
---

<div class="podcast-player" data-player-id={playerId}>
  <div class="podcast-header">
    <div class="podcast-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="9"/>
        <path d="M9 9l6 3-6 3V9z" fill="currentColor" stroke="none"/>
      </svg>
    </div>
    <div class="podcast-meta">
      <p class="podcast-label">收聽 Podcast 精華</p>
      <p class="podcast-title">{title}</p>
      {episode && <p class="podcast-ep">{episode}</p>}
    </div>
  </div>

  <audio id={playerId} src={src} preload="metadata" class="sr-only"></audio>

  <div class="podcast-controls">
    <button
      class="play-btn"
      data-audio={playerId}
      aria-label="播放"
      type="button"
    >
      <svg class="icon-play" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
      </svg>
      <svg class="icon-pause hidden" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
    </button>

    <div class="progress-wrap">
      <div class="time-elapsed" data-audio={playerId}>0:00</div>
      <div class="progress-bar-track" data-audio={playerId} role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
        <div class="progress-bar-fill"></div>
        <input type="range" class="progress-range" min="0" max="100" value="0" step="0.1" aria-label="播放進度" data-audio={playerId} />
      </div>
      <div class="time-total" data-audio={playerId}>--:--</div>
    </div>
  </div>

  <p class="podcast-hosts">小雅 × 志豪　雙人深度討論本篇重點</p>
</div>

<style>
  .podcast-player {
    margin: 2.5rem 0;
    padding: 1.25rem 1.5rem;
    background: var(--color-paper-warm, #FAF7F2);
    border: 1px solid var(--color-rule-bold, #d0c4b0);
    border-left: 3px solid var(--color-primary, #C9A96E);
    border-radius: 8px;
    font-family: var(--font-body-cjk, sans-serif);
  }

  .podcast-header {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    margin-bottom: 1rem;
  }

  .podcast-icon {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    color: var(--color-primary, #C9A96E);
    margin-top: 0.125rem;
  }
  .podcast-icon svg { width: 100%; height: 100%; }

  .podcast-meta { min-width: 0; }

  .podcast-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary, #C9A96E);
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .podcast-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink, #3B2A1A);
    margin: 0;
    line-height: 1.4;
  }

  .podcast-ep {
    font-size: 12px;
    color: var(--color-ink-muted, #7a6454);
    margin: 0.2rem 0 0;
  }

  .podcast-controls {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .play-btn {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: none;
    background: var(--color-primary, #C9A96E);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    padding: 0;
  }
  .play-btn:hover { background: var(--color-primary-soft, #D4854A); transform: scale(1.05); }
  .play-btn:active { transform: scale(0.97); }
  .play-btn svg { width: 1rem; height: 1rem; }

  .progress-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .time-elapsed,
  .time-total {
    font-size: 11px;
    font-variant-numeric: tabular-nums;
    color: var(--color-ink-muted, #7a6454);
    flex-shrink: 0;
    letter-spacing: 0.03em;
  }

  .progress-bar-track {
    flex: 1;
    height: 4px;
    background: var(--color-rule-hair, #e0d6cc);
    border-radius: 2px;
    position: relative;
    cursor: pointer;
  }

  .progress-bar-fill {
    height: 100%;
    width: 0%;
    background: var(--color-primary, #C9A96E);
    border-radius: 2px;
    pointer-events: none;
    transition: width 0.1s linear;
  }

  .progress-range {
    position: absolute;
    inset: -8px 0;
    width: 100%;
    height: calc(100% + 16px);
    opacity: 0;
    cursor: pointer;
    margin: 0;
  }

  .podcast-hosts {
    margin: 0.75rem 0 0;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-ink-faint, #a89880);
  }

  .hidden { display: none !important; }
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); border: 0;
  }

  @media (max-width: 480px) {
    .podcast-player { padding: 1rem 1.125rem; }
    .play-btn { width: 2.25rem; height: 2.25rem; }
    .play-btn svg { width: 0.875rem; height: 0.875rem; }
  }
</style>

<script>
  function initPlayer(player: HTMLElement) {
    const id = player.dataset.playerId!;
    const audio = document.getElementById(id) as HTMLAudioElement;
    const playBtn = player.querySelector<HTMLButtonElement>(".play-btn");
    const iconPlay = player.querySelector<SVGElement>(".icon-play");
    const iconPause = player.querySelector<SVGElement>(".icon-pause");
    const fill = player.querySelector<HTMLElement>(".progress-bar-fill");
    const range = player.querySelector<HTMLInputElement>(".progress-range");
    const elapsed = player.querySelector<HTMLElement>(".time-elapsed");
    const total = player.querySelector<HTMLElement>(".time-total");

    if (!audio || !playBtn) return;

    const fmt = (s: number) => {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, "0")}`;
    };

    audio.addEventListener("loadedmetadata", () => {
      if (total) total.textContent = fmt(audio.duration);
    });

    audio.addEventListener("timeupdate", () => {
      const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      if (fill) fill.style.width = `${pct}%`;
      if (range) range.value = String(pct);
      if (elapsed) elapsed.textContent = fmt(audio.currentTime);
    });

    audio.addEventListener("play", () => {
      iconPlay?.classList.add("hidden");
      iconPause?.classList.remove("hidden");
      playBtn.setAttribute("aria-label", "暫停");
    });

    audio.addEventListener("pause", () => {
      iconPlay?.classList.remove("hidden");
      iconPause?.classList.add("hidden");
      playBtn.setAttribute("aria-label", "播放");
    });

    audio.addEventListener("ended", () => {
      iconPlay?.classList.remove("hidden");
      iconPause?.classList.add("hidden");
    });

    playBtn.addEventListener("click", () => {
      if (audio.paused) {
        document.querySelectorAll("audio").forEach((a) => { if (a !== audio) a.pause(); });
        audio.play();
      } else {
        audio.pause();
      }
    });

    if (range) {
      range.addEventListener("input", () => {
        if (audio.duration) {
          audio.currentTime = (parseFloat(range.value) / 100) * audio.duration;
        }
      });
    }
  }

  document.querySelectorAll<HTMLElement>(".podcast-player").forEach(initPlayer);
</script>
