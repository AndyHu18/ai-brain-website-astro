---
// Andy 大幅照片 — Aesop / 編輯式 portrait
// 不要圓形、不要 mask 過度、保持人像沉穩
---
<figure class="hero-portrait relative max-lg:hidden self-end" aria-hidden="true">
  <div class="hero-portrait-glow absolute inset-[-15%] z-0 pointer-events-none"></div>
  <div class="relative z-10 overflow-hidden">
    <img
      src="/andy-photo.png"
      alt=""
      class="hero-portrait-img w-[420px] h-[540px] object-cover object-top block"
      loading="eager"
      decoding="async"
    />
  </div>
  {/* 編輯式 caption — 像雜誌底部標註 */}
  <figcaption class="absolute bottom-3 right-0 z-20
                     eyebrow text-[var(--color-paper)]
                     mix-blend-difference
                     pl-3 border-l border-[var(--color-paper)]/40">
    Andy &middot; 主筆
  </figcaption>
</figure>

<style>
  .hero-portrait-glow {
    background: radial-gradient(ellipse 80% 70% at 50% 40%, oklch(0.557 0.166 45 / 0.35) 0%, transparent 65%);
    filter: blur(50px);
  }
  .hero-portrait-img {
    /* 漸變淡出底部 + 左側 — 編輯式融入 */
    mask-image:
      linear-gradient(to bottom, transparent 0%, black 8%, black 88%, transparent 100%),
      linear-gradient(to right, transparent 0%, black 30%, black 100%);
    mask-composite: intersect;
    -webkit-mask-image:
      linear-gradient(to bottom, transparent 0%, black 8%, black 88%, transparent 100%),
      linear-gradient(to right, transparent 0%, black 30%, black 100%);
    -webkit-mask-composite: source-in;
    filter: brightness(1.02) contrast(1.06) saturate(0.95);
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-portrait:hover .hero-portrait-img {
    transform: scale(1.015);
  }
</style>
