---
import { SITE, SERIES_ARTICLES, BASE_PATH } from "../consts";
interface Props {
  articleNum?: string;
}
const { articleNum } = Astro.props;
const seriesHref = articleNum ? `${SITE.overviewUrl}#article-${articleNum}` : SITE.overviewUrl;
---

<nav
  class="navbar-shell fixed top-0 inset-x-0 z-[1000]
         bg-[var(--color-paper)]/85 backdrop-blur-lg
         border-b border-[var(--color-rule-hair)]"
  role="navigation"
  aria-label="主選單"
>
  <div class="container-wide h-full flex items-center justify-between gap-4">

    {/* 左：品牌 — 文章頁手機加回上箭頭 */}
    <div class="flex items-center gap-1">
      {articleNum && (
        <a
          href={SITE.overviewUrl}
          class="flex items-center justify-center min-w-[44px] min-h-[44px] -ml-2
                 text-[1.1rem] leading-none
                 text-[var(--color-ink-muted)] hover:text-[var(--color-primary)]
                 active:text-[var(--color-primary-deep)]
                 transition-colors duration-300"
          aria-label="返回系列總覽"
        >←</a>
      )}
      <a
        href={SITE.mainSiteUrl}
        class="group flex items-center gap-1 whitespace-nowrap"
        title="返回 AI 智能大腦主站"
      >
        <span class="font-display-cjk font-black text-[1.0625rem] md:text-lg tracking-tight text-[var(--color-ink)]
                     group-hover:text-[var(--color-primary)] transition-colors duration-300">
          AI 智能大腦
        </span>
        <span class="text-[var(--color-primary)] text-lg font-black">.</span>
      </a>
    </div>

    {/* 中：系列 label — 768px 以上才出現 */}
    <a
      href={seriesHref}
      class="hidden md:inline-flex items-center gap-2
             px-3 py-1.5
             eyebrow text-[var(--color-ink-muted)]
             border border-[var(--color-rule-hair)] rounded-full
             hover:border-[var(--color-rule-bold)] hover:text-[var(--color-primary)]
             transition-all duration-300"
    >
      <span class="w-1 h-1 rounded-full bg-[var(--color-primary)]" aria-hidden="true"></span>
      網站經營 12 篇系列
    </a>

    {/* 右：漢堡 (mobile only) + CTA */}
    <div class="flex items-center gap-1.5">

      {/* 漢堡按鈕 — 手機專用 */}
      <button
        id="nav-hamburger"
        type="button"
        aria-expanded="false"
        aria-controls="nav-panel"
        aria-label="開啟選單"
        class="md:hidden flex flex-col justify-center items-center
               w-11 h-11 gap-[5.5px] rounded-lg
               text-[var(--color-ink)]
               hover:bg-[var(--color-paper-warm)]
               active:bg-[var(--color-paper-deep)]
               transition-colors duration-200
               touch-action-manipulation"
      >
        <span class="ham-l"></span>
        <span class="ham-l"></span>
        <span class="ham-l"></span>
      </button>

      {/* CTA */}
      <a
        href={SITE.ctaUrl}
        target="_blank"
        rel="noopener"
        class="group inline-flex items-center gap-2 min-h-[44px]
               px-4 md:px-5 py-2.5
               text-[13px] font-semibold
               text-[var(--color-paper)]
               bg-[var(--color-ink)]
               hover:bg-[var(--color-primary)]
               active:scale-[0.97]
               rounded-full
               transition-all duration-300
               whitespace-nowrap"
      >
        <span>免費診斷</span>
        <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</nav>

{/* ====================================================
    漢堡導覽面板（手機滑入側欄）
    ==================================================== */}

{/* 遮罩層 */}
<div
  id="nav-overlay"
  class="nav-overlay fixed inset-0 z-[1100]
         bg-[var(--color-ink)]/40 backdrop-blur-[2px]
         opacity-0 pointer-events-none
         transition-opacity duration-300"
  aria-hidden="true"
></div>

{/* 側欄面板 */}
<aside
  id="nav-panel"
  role="dialog"
  aria-modal="true"
  aria-label="系列導覽選單"
  class="nav-panel fixed top-0 right-0 z-[1200]
         w-[min(320px,85vw)] h-full
         bg-[var(--color-paper)]
         shadow-2xl
         flex flex-col
         translate-x-full
         transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
>
  {/* 面板標頭 — 高度與 navbar 一致 */}
  <header class="nav-panel-header flex-none flex items-center justify-between px-5
                 border-b border-[var(--color-rule-hair)]">
    <span class="font-display-cjk font-black text-[1rem] tracking-tight text-[var(--color-ink)]">
      AI 智能大腦<span class="text-[var(--color-primary)]">.</span>
    </span>
    <button
      id="nav-close"
      type="button"
      aria-label="關閉選單"
      class="flex items-center justify-center w-11 h-11 rounded-lg
             text-[var(--color-ink-muted)]
             hover:text-[var(--color-ink)]
             hover:bg-[var(--color-paper-warm)]
             active:bg-[var(--color-paper-deep)]
             transition-colors duration-200"
    >
      {/* X 圖示 */}
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M3 3l12 12M15 3L3 15"/>
      </svg>
    </button>
  </header>

  {/* 捲動區域 */}
  <div class="flex-1 overflow-y-auto overscroll-contain">

    {/* 返回主站連結（最顯眼,在嵌入式環境下提供回主品牌站的明確路徑） */}
    <a
      href={SITE.mainSiteUrl}
      class="nav-panel-link flex items-center gap-3 px-5 py-4
             border-b-2 border-[var(--color-primary)]
             bg-[var(--color-paper-blush)]
             text-[var(--color-ink)] hover:bg-[var(--color-primary)]
             hover:text-[var(--color-paper)]
             active:bg-[var(--color-primary-deep)]
             transition-colors duration-200"
    >
      <span class="flex-none flex items-center justify-center
                   w-7 h-7 rounded-full
                   bg-[var(--color-primary)]
                   text-[14px] font-bold leading-none
                   text-[var(--color-paper)]">
        ←
      </span>
      <span class="text-[14px] font-semibold">
        返回 AI 智能大腦主站
      </span>
    </a>

    {/* 系列總覽連結 */}
    <a
      href={SITE.overviewUrl}
      class="nav-panel-link flex items-center gap-3 px-5 py-4
             border-b border-[var(--color-rule-hair)]
             text-[var(--color-ink-muted)] hover:text-[var(--color-primary)]
             hover:bg-[var(--color-paper-warm)]
             active:bg-[var(--color-paper-deep)]
             transition-colors duration-200"
    >
      <span class="flex-none flex items-center justify-center
                   w-7 h-7 rounded-full
                   bg-[var(--color-paper-deep)]
                   text-[10px] tracking-widest font-semibold
                   text-[var(--color-ink-faint)]">
        ☰
      </span>
      <span class="eyebrow text-[12px] tracking-[0.15em] text-[var(--color-ink-muted)]">
        12 篇系列總覽
      </span>
    </a>

    {/* 12 篇文章清單 */}
    <nav aria-label="文章列表">
      {SERIES_ARTICLES.map(a => (
        <a
          href={`${BASE_PATH}/articles/${a.slug}/`}
          class={`nav-panel-link flex items-center gap-3 px-5 py-3.5
                  border-b border-[var(--color-rule-hair)]
                  hover:bg-[var(--color-paper-warm)]
                  active:bg-[var(--color-paper-deep)]
                  transition-colors duration-200
                  ${articleNum === a.num ? "bg-[var(--color-paper-blush)]" : ""}`}
        >
          {/* 篇號 */}
          <span class="flex-none flex items-center justify-center
                       w-7 h-7 rounded-full
                       bg-[var(--color-paper-deep)]
                       text-[11px] font-semibold tabular-nums
                       text-[var(--color-primary)]">
            {a.num}
          </span>
          {/* 文字 */}
          <span class="flex-1 min-w-0">
            <span class="block text-[12px] tracking-[0.15em] text-[var(--color-primary)] font-semibold uppercase mb-0.5">
              {a.badge}
            </span>
            <span class={`block text-[14px] leading-snug font-medium
                          ${articleNum === a.num ? "text-[var(--color-primary)]" : "text-[var(--color-ink)]"}`}>
              {a.shortTitle}
            </span>
          </span>
          {/* 當前篇指示 */}
          {articleNum === a.num && (
            <span class="flex-none w-1.5 h-1.5 rounded-full bg-[var(--color-primary)]" aria-label="目前篇章"></span>
          )}
        </a>
      ))}
    </nav>
  </div>

  {/* 底部 CTA — 固定在底部，含 iOS 安全區 */}
  <footer class="nav-panel-footer flex-none px-5 pt-4 border-t border-[var(--color-rule-hair)]">
    <a
      href={SITE.ctaUrl}
      target="_blank"
      rel="noopener"
      class="group flex items-center justify-center gap-2
             w-full min-h-[48px]
             bg-[var(--color-ink)] hover:bg-[var(--color-primary)]
             active:scale-[0.98]
             text-[var(--color-paper)] text-[14px] font-semibold
             rounded-full
             transition-all duration-300"
    >
      加 LINE 免費診斷
      <span class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">→</span>
    </a>
  </footer>
</aside>

<style>
  /* ── Navbar 高度 ── */
  .navbar-shell {
    height: calc(4rem + env(safe-area-inset-top));
    padding-top: env(safe-area-inset-top);
  }
  @media (min-width: 768px) {
    .navbar-shell {
      height: calc(5rem + env(safe-area-inset-top));
    }
  }

  /* ── 漢堡三條線 ── */
  .ham-l {
    display: block;
    width: 20px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transform-origin: center;
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.2s ease;
  }

  /* 展開時變 X */
  #nav-hamburger[aria-expanded="true"] .ham-l:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }
  #nav-hamburger[aria-expanded="true"] .ham-l:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #nav-hamburger[aria-expanded="true"] .ham-l:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* ── 面板標頭高度與 navbar 同步 ── */
  .nav-panel-header {
    height: calc(4rem + env(safe-area-inset-top));
    padding-top: env(safe-area-inset-top);
  }

  /* ── 面板底部 iOS 安全區 ── */
  .nav-panel-footer {
    padding-bottom: calc(1.25rem + env(safe-area-inset-bottom));
  }
</style>

<script>
  const hamburger = document.getElementById("nav-hamburger") as HTMLButtonElement;
  const panel     = document.getElementById("nav-panel") as HTMLElement;
  const overlay   = document.getElementById("nav-overlay") as HTMLElement;
  const closeBtn  = document.getElementById("nav-close") as HTMLButtonElement;

  function openMenu() {
    hamburger.setAttribute("aria-expanded", "true");
    hamburger.setAttribute("aria-label", "關閉選單");
    panel.classList.remove("translate-x-full");
    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");
    document.body.style.overflow = "hidden";
    // 延遲 focus 等動畫開始
    setTimeout(() => closeBtn.focus(), 50);
  }

  function closeMenu() {
    hamburger.setAttribute("aria-expanded", "false");
    hamburger.setAttribute("aria-label", "開啟選單");
    panel.classList.add("translate-x-full");
    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.classList.remove("opacity-100");
    document.body.style.overflow = "";
    hamburger.focus();
  }

  hamburger.addEventListener("click", () => {
    const isOpen = hamburger.getAttribute("aria-expanded") === "true";
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn.addEventListener("click", closeMenu);
  overlay.addEventListener("click", closeMenu);

  // ESC 關閉
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape" && hamburger.getAttribute("aria-expanded") === "true") {
      closeMenu();
    }
  });

  // 點擊面板內的連結後自動關閉
  panel.querySelectorAll("a.nav-panel-link").forEach(link => {
    link.addEventListener("click", closeMenu);
  });
</script>
