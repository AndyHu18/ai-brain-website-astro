---
import { SITE } from "../consts";
interface Props {
  articleNum: string;
}
const { articleNum } = Astro.props;
const href = `${SITE.overviewUrl}#article-${articleNum}`;
---

<a
  href={href}
  class="bto-pill group fixed z-[1100]
         hidden md:inline-flex items-center gap-2
         px-3.5 py-2 pl-3
         bg-[var(--color-ink-midnight)]
         text-[var(--color-paper)]
         border border-[var(--color-rule-bold)]
         rounded-full
         text-[12px] font-semibold tracking-wide
         shadow-[0_8px_24px_-8px_rgba(0,0,0,0.35)]
         backdrop-blur-md
         hover:bg-[var(--color-primary)]
         hover:border-[var(--color-honey)]
         hover:-translate-x-0.5
         hover:shadow-[0_12px_28px_-8px_oklch(0.557_0.166_45_/_0.45)]
         transition-all duration-300 ease-out"
  aria-label="回到系列總覽"
>
  <span
    class="text-[14px] transition-transform duration-300 group-hover:-translate-x-0.5"
    aria-hidden="true"
  >←</span>
  <span>系列總覽</span>
  <span class="hidden md:inline-block opacity-50 text-[10px] font-light tracking-wider
               pl-2.5 ml-0.5 border-l border-[var(--color-rule-bold)]">
    12 篇導讀
  </span>
</a>

<style>
  /* BTO 位置：navbar 下方 + iOS 安全區 + 左側 padding */
  .bto-pill {
    top: calc(5rem + env(safe-area-inset-top) + 0.75rem);
    left: calc(1.5rem + env(safe-area-inset-left));
  }
</style>
