---
import { SERIES_ARTICLES, BASE_PATH } from "../consts";

interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
  currentNum: string;
}
const { headings, currentNum } = Astro.props;
const tocItems = headings.filter(h => h.depth === 2);
---

<aside
  class="sidebar hidden lg:block
         lg:sticky lg:top-24 lg:max-h-[calc(100vh-7rem)] lg:overflow-y-auto
         lg:pr-2"
  aria-label="文章導覽"
>
  {tocItems.length > 0 && (
    <section class="mb-12">
      <header class="flex items-center gap-3 mb-5">
        <span class="eyebrow eyebrow-primary">本文目錄</span>
        <hr class="rule-hairline flex-1" />
      </header>
      <ol class="space-y-1">
        {tocItems.map((item, idx) => (
          <li>
            <a
              href={`#${item.slug}`}
              data-toc-link={item.slug}
              class="toc-link group block py-2 pl-4 pr-2
                     border-l border-[var(--color-rule-hair)]
                     text-[14px] leading-snug
                     text-[var(--color-ink-muted)]
                     hover:text-[var(--color-primary)]
                     hover:border-[var(--color-primary)]
                     transition-all duration-300"
            >
              <span class="tabular-display text-[11px] tracking-wider mr-2 text-[var(--color-ink-faint)]
                           group-hover:text-[var(--color-primary)] transition-colors">
                {String(idx + 1).padStart(2, "0")}
              </span>
              {item.text}
            </a>
          </li>
        ))}
      </ol>
    </section>
  )}

  <section>
    <header class="flex items-center gap-3 mb-5">
      <span class="eyebrow eyebrow-primary">系列篇章</span>
      <hr class="rule-hairline flex-1" />
    </header>
    <ol class="space-y-0.5">
      {SERIES_ARTICLES.map(a => {
        const isCurrent = a.num === currentNum;
        return (
          <li>
            <a
              href={`${BASE_PATH}/articles/${a.slug}/`}
              aria-current={isCurrent ? 'page' : undefined}
              class={`group flex items-baseline gap-3 py-2.5 px-3
                      border-b border-[var(--color-rule-hair)]
                      transition-all duration-300
                      ${isCurrent
                        ? 'bg-[var(--color-paper-blush)] text-[var(--color-ink)]'
                        : 'text-[var(--color-ink-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-paper-warm)]'}`}
            >
              <span class={`tabular-display text-[11px] tracking-[0.15em]
                            ${isCurrent ? 'text-[var(--color-primary)]' : 'text-[var(--color-ink-faint)]'}`}>
                {a.num}
              </span>
              <span class="text-[13px] leading-snug">
                {a.shortTitle}
              </span>
              {isCurrent && (
                <span class="ml-auto w-1 h-1 rounded-full bg-[var(--color-primary)]" aria-hidden="true"></span>
              )}
            </a>
          </li>
        );
      })}
    </ol>
  </section>
</aside>

<script>
  // TOC 滾動高亮 — 編輯式 active state（左邊條變橘）
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");
  const linkBySlug = new Map<string, HTMLAnchorElement>();
  links.forEach((l) => {
    const slug = l.getAttribute("data-toc-link");
    if (slug) linkBySlug.set(slug, l);
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const id = entry.target.id;
        if (!id) return;
        const link = linkBySlug.get(id);
        if (!link || !entry.isIntersecting) return;
        links.forEach((l) => l.classList.remove("toc-active"));
        link.classList.add("toc-active");
      });
    },
    { rootMargin: "-15% 0px -65% 0px" }
  );
  // .article-body 比 article 更精確（避免抓到 RelatedArticles 等其他區塊的 h2）
  document.querySelectorAll(".article-body h2[id]").forEach((h) => observer.observe(h));
</script>

<style>
  .toc-link.toc-active {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    border-left-width: 2px;
    padding-left: calc(1rem - 1px);
  }
</style>
