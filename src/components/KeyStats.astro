---
// Bloomberg / Economist 風格 — 大數字 + 細描述 + 直線分隔
interface Props {
  stats: Array<{ num: string; label: string }>;
}
const { stats } = Astro.props;
---

<div class="key-stats reveal mt-12 md:mt-16 mb-4">
  {/* 上方 hairline + eyebrow */}
  <div class="flex items-center gap-3 mb-6">
    <span class="eyebrow eyebrow-primary">數據速覽</span>
    <hr class="rule-hairline flex-1" />
  </div>

  <dl class="grid grid-cols-1 sm:grid-cols-3 gap-y-8 sm:gap-y-0 sm:gap-x-0">
    {stats.map((s, i) => (
      <div class={`flex flex-col px-0 sm:px-6 py-1
                   ${i > 0 ? 'sm:border-l border-[var(--color-rule-soft)]' : ''}
                   ${i === 0 ? 'sm:pl-0' : ''}`}>
        <dt class="tabular-display text-[2.5rem] sm:text-[3rem] md:text-[3.5rem] leading-none
                   font-medium text-[var(--color-primary)]
                   tracking-tight">
          {s.num}
        </dt>
        <dd class="mt-3 sm:mt-4 text-[13px] leading-snug
                   text-[var(--color-ink-muted)]
                   max-w-[20ch]">
          {s.label}
        </dd>
      </div>
    ))}
  </dl>
</div>

<style>
  .tabular-display {
    font-family: var(--font-display-latin);
    font-feature-settings: "tnum" 1, "lnum" 1;
    font-variant-numeric: tabular-nums;
    /* Fraunces optical sizing — 大號字用 display 模式 */
    font-variation-settings: "opsz" 96, "SOFT" 50;
  }
</style>
