---
// 系列總覽 hero 用的大張 Andy portrait（編輯式封面照）
---
<figure class="series-portrait relative max-lg:hidden self-end" aria-hidden="true">
  <div class="series-portrait-glow absolute inset-[-15%] z-0 pointer-events-none"></div>
  <img
    src="/andy-photo.png"
    alt=""
    class="series-portrait-img relative z-10 w-[480px] h-[600px] object-cover object-top block"
    loading="eager"
    decoding="async"
  />
</figure>

<style>
  .series-portrait-glow {
    background: radial-gradient(ellipse 80% 70% at 50% 40%, oklch(0.557 0.166 45 / 0.42) 0%, transparent 65%);
    filter: blur(60px);
  }
  .series-portrait-img {
    mask-image:
      linear-gradient(to bottom, transparent 0%, black 6%, black 88%, transparent 100%),
      linear-gradient(to right, transparent 0%, black 28%, black 100%);
    mask-composite: intersect;
    -webkit-mask-image:
      linear-gradient(to bottom, transparent 0%, black 6%, black 88%, transparent 100%),
      linear-gradient(to right, transparent 0%, black 28%, black 100%);
    -webkit-mask-composite: source-in;
    filter: brightness(1.02) contrast(1.06) saturate(0.95);
  }
</style>
